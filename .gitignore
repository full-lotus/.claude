# Claude Code .gitignore
# Excludes temporary files, caches, and sensitive data from version control

# Sensitive data
settings.local.json

# Temporary and cache directories
debug/
cache/
downloads/
file-history/
paste-cache/
shell-snapshots/
backups/

# Session and task data
session-env/
tasks/
todos/
projects/
plans/

# Conversation history
history.jsonl

# Plugins
plugins/cache/
/plugins/blocklist.json
plugins/known_marketplaces.json

# Ignore .git directory itself
.git/
